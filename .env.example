# GigaChat OAuth: base64("client_id:client_secret")
GIGACHAT_AUTH_KEY=

# Zabbix JSON-RPC endpoint, напр. http://zabbix.example.com/api_jsonrpc.php
ZABBIX_URL=
ZABBIX_USER=Admin
ZABBIX_PASS=

# Имя хоста в Zabbix, привязанного к этому инструменту (single-tenant MVP)
BOUND_HOST=

# Необязательно
GIGACHAT_MODEL=GigaChat-2-Pro
HOST=127.0.0.1
PORT=8080
