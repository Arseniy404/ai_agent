# ── GigaChat ──────────────────────────────────────────────────────────────
GIGACHAT_AUTH_KEY=
GIGACHAT_MODEL=GigaChat-2-Pro
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ── SELF-портал (корпоративный) ─────────────────────────────────────────────
SELF_BASE=https://selfportalift.csim.delta.sbrf.ru
# mTLS: пути к сертификату и ключу (по умолчанию ./Certificate.txt и ./Key.txt)
SELF_CERT=./Certificate.txt
SELF_KEY=./Key.txt
# Проверка серверного TLS: путь к CA-бандлу, либо 0 чтобы отключить
SELF_VERIFY=0

# ── HTTP ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8077
